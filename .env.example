# =============================================================================
# Lumina monorepo — environment variable template
# =============================================================================
# Copy this file to `.env` (and / or per-artifact `.env` files) and fill in
# real values. NEVER commit real secrets — the root .gitignore blocks every
# .env / .env.* file except this template.
#
# On Replit, most values below are injected automatically by the platform
# (Secrets pane, integration setup, or the runtime container). This file
# documents the full surface for forks, local dev, and self-hosted setups.
#
# Conventions:
#   - Variables prefixed `EXPO_PUBLIC_` are bundled into the mobile/web
#     client at build time. Treat them as PUBLIC — never put a real
#     server-side secret behind that prefix.
#   - Variables without that prefix are server-only (api-server) and
#     never reach the client.
# =============================================================================


# ---------------------------------------------------------------------------
# Replit platform (auto-provided at runtime — do not set manually in prod)
# ---------------------------------------------------------------------------
REPL_ID=
REPLIT_DEV_DOMAIN=
REPLIT_INTERNAL_APP_DOMAIN=
REPLIT_EXPO_DEV_DOMAIN=


# ---------------------------------------------------------------------------
# Core server runtime
# ---------------------------------------------------------------------------
# Port for the api-server process (the platform sets this; default is 8080).
PORT=8080
# "development" | "production"
NODE_ENV=development
# Pino log level: "trace" | "debug" | "info" | "warn" | "error" | "fatal"
LOG_LEVEL=info
# Base path that the api-server is mounted under (proxy injects /api).
BASE_PATH=/


# ---------------------------------------------------------------------------
# Database (required — server throws on boot if missing)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME


# ---------------------------------------------------------------------------
# Session signing (required for any cookie-backed flow)
# ---------------------------------------------------------------------------
# Long random string. Generate with: openssl rand -base64 48
SESSION_SECRET=replace-me-with-a-long-random-string


# ---------------------------------------------------------------------------
# Clerk authentication
# Server-side secret + matching publishable key are forwarded into the
# client bundle by artifacts/lumina/scripts/build.js.
# ---------------------------------------------------------------------------
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_PUBLISHABLE_KEY=pk_test_replace_me
# Path on this domain where the Clerk Frontend API proxy is mounted.
CLERK_PROXY_URL=/api/__clerk
# Svix signing secret for the Clerk webhook endpoint (/api/webhooks/clerk).
# Required in production for user-deletion sync and profile updates.
# Found in Clerk Dashboard → Webhooks → Signing Secret.
# Without this, the webhook endpoint returns 503.
# Where to set:
#   Replit web deploy: Secrets pane
#   Native/TestFlight:  Secrets pane (server-side only, not bundled into app)
CLERK_WEBHOOK_SECRET=whsec_replace_me

# Mirrors of the above that the Expo bundle reads at runtime. The
# `dev` script in artifacts/lumina/package.json forwards the server
# values into these names automatically — set them here only when
# running the mobile app outside of that script.
#
# EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY (REQUIRED for mobile auth)
#   The Clerk publishable key from the Clerk Dashboard → API Keys.
#   Where to set:
#     Replit web deploy: Secrets pane (auto-forwarded to Expo web bundle)
#     Native/TestFlight:  eas.json env block OR EAS Secrets
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
# EXPO_PUBLIC_CLERK_PROXY_URL (optional)
#   Only needed when Clerk Frontend API should go through the server proxy.
EXPO_PUBLIC_CLERK_PROXY_URL=
# EXPO_PUBLIC_DOMAIN (REQUIRED for native builds)
#   The fully-qualified domain (no protocol) where the API server is reachable.
#   On Replit web preview this is auto-resolved; on native builds the app
#   calls setBaseUrl(`https://${EXPO_PUBLIC_DOMAIN}`) so API requests work.
#   Where to set:
#     Replit web deploy: not needed (proxy handles routing)
#     Native/TestFlight:  eas.json env block OR EAS Secrets
#                         Value: your-repl.replit.app (the deployed domain)
EXPO_PUBLIC_DOMAIN=
EXPO_PUBLIC_REPL_ID=


# ---------------------------------------------------------------------------
# Stripe (optional — billing/payouts return 503 cleanly when unset)
# NOT REQUIRED for closed beta (monetization is archived by default).
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PRICE_ID_PRO=price_replace_me
STRIPE_BILLING_RETURN_URL=lumina://billing/return
STRIPE_CONNECT_REFRESH_URL=lumina://connect/refresh
STRIPE_CONNECT_RETURN_URL=lumina://connect/return
STRIPE_WEBHOOK_SECRET=whsec_replace_me


# ---------------------------------------------------------------------------
# Anthropic (Replit AI Integrations proxy — auto-provisioned by integration)
# Set via setupReplitAIIntegrations({ providerSlug: "anthropic", ... }).
# ---------------------------------------------------------------------------
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=
AI_INTEGRATIONS_ANTHROPIC_API_KEY=


# ---------------------------------------------------------------------------
# Admin dashboard (server-side)
# ---------------------------------------------------------------------------
# Bearer token for /api/admin/* endpoints (error dashboard, AI usage, overview).
# Must be a strong random string (≥32 chars). Generate with: openssl rand -base64 48
# Without this, admin endpoints return 404.
# Where to set:
#   Replit web deploy: Secrets pane
#   Native/TestFlight:  Secrets pane (server-side only, not bundled into app)
LUMINA_ADMIN_TOKEN=replace-me-with-a-long-random-string


# ---------------------------------------------------------------------------
# Per-creator daily quotas (server-side, optional — defaults below)
# ---------------------------------------------------------------------------
LUMINA_MAX_SWARM_RUNS_PER_DAY=10
LUMINA_MAX_IDEA_BATCHES_PER_DAY=2


# ---------------------------------------------------------------------------
# Feature flags — Phase 1 frozen subsystems (server)
# ON (default) keeps the subsystem archived. Set to "false" to wake it up.
# NOT REQUIRED for closed beta — all default to ON (archived).
# The closed beta ships only the core ideation loop.
# ---------------------------------------------------------------------------
ARCHIVED_AUTONOMY=true
ARCHIVED_MONETIZATION=true
ARCHIVED_POSTING=true


# ---------------------------------------------------------------------------
# Feature flags — Phase 1 frozen subsystems (client mirror)
# NOT REQUIRED for closed beta — all default to ON (archived).
# ---------------------------------------------------------------------------
EXPO_PUBLIC_ARCHIVED_AUTONOMY=true
EXPO_PUBLIC_ARCHIVED_MONETIZATION=true
EXPO_PUBLIC_ARCHIVED_POSTING=true


# ---------------------------------------------------------------------------
# Mobile app — UX / build switches
# ---------------------------------------------------------------------------
# When "true" AND running on web, Clerk is bypassed and the api-server
# falls back to the seeded demo creator. Native builds ignore this.
EXPO_PUBLIC_WEB_QA_MODE=false
# Forces the Taste Calibration prompt to re-surface (DEV builds only).
EXPO_PUBLIC_FORCE_CALIBRATION=false
# Toggles the cinematic onboarding variant.
EXPO_PUBLIC_USE_CINEMATIC_ONBOARDING=false
# "real" → use OAuth posting clients; anything else → mocks.
EXPO_PUBLIC_PUBLISHER_BACKEND=mock
# Currently informational; reserved for future on-device inference work.
EXPO_PUBLIC_INFERENCE_BACKEND=


# ---------------------------------------------------------------------------
# Mobile OAuth — sandbox vs production toggle + per-platform credentials
# ---------------------------------------------------------------------------
# Anything other than "production" runs each provider in sandbox mode.
EXPO_PUBLIC_PLATFORM_MODE=sandbox
# Custom URL scheme used by OAuth redirects (matches app.json `scheme`).
EXPO_PUBLIC_REDIRECT_SCHEME=lumina

# WARNING: the EXPO_PUBLIC_ prefix means these get bundled into the
# client binary. Use SANDBOX credentials here; production OAuth flows
# should be moved to a backend code-exchange endpoint before shipping
# real client secrets to user devices.
EXPO_PUBLIC_TIKTOK_CLIENT_ID=
EXPO_PUBLIC_TIKTOK_CLIENT_SECRET=
EXPO_PUBLIC_INSTAGRAM_CLIENT_ID=
EXPO_PUBLIC_INSTAGRAM_CLIENT_SECRET=
EXPO_PUBLIC_YOUTUBE_CLIENT_ID=
EXPO_PUBLIC_YOUTUBE_CLIENT_SECRET=
